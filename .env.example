# Optional: point to a Python environment where edge-tts is installed.
# QUALITY_GLOSSARY_EDGE_TTS_PYTHON=C:\path\to\python.exe

# Optional: customize the default English TTS voice.
QUALITY_GLOSSARY_TTS_VOICE=en-US-AndrewNeural
QUALITY_GLOSSARY_TTS_RATE=-13%
QUALITY_GLOSSARY_TTS_PITCH=+1Hz
QUALITY_GLOSSARY_TTS_VOLUME=+0%

